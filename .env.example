# Schyrim AI Provider Configuration
# Copy this file to .env (which is not tracked by git) and add your API keys
# Leave keys blank for disabled providers — game will use the next available provider in priority order

# === ANTHROPIC (Claude) ===
# Get API key from: https://console.anthropic.com/
# Free tier available: https://www.anthropic.com/pricing
# Recommended for best quality
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# === OPENROUTER (Multi-provider) ===
# Get API key from: https://openrouter.ai/
# Supports 100+ models from Meta, Mistral, Llama, and more
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# === GROQ (Fast inference) ===
# Get API key from: https://console.groq.com/
# Fastest inference, great for real-time responses
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# === OPENAI (ChatGPT) ===
# Get API key from: https://platform.openai.com/api-keys
# Reliable, well-known, good quality
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# === GOOGLE GEMINI ===
# Get API key from: https://ai.google.dev/
# Competitive quality, good for experimentation
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# === TOGETHER AI ===
# Get API key from: https://www.together.ai/
# Good speed/quality ratio, fast inference
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Llama-3-70b-chat-hf

# === OLLAMA (Local/Self-Hosted) ===
# Start Ollama: ollama serve (runs on localhost:11434)
# Completely offline, privacy-focused
OLLAMA_ENDPOINT=
OLLAMA_MODEL=llama2

# === PROVIDER PRIORITY ===
# If multiple API keys are set, Schyrim will use this priority:
#   1. ANTHROPIC_API_KEY (Claude)
#   2. OPENROUTER_API_KEY (100+ models)
#   3. GROQ_API_KEY (fast)
#   4. OPENAI_API_KEY (ChatGPT)
#   5. GEMINI_API_KEY (Google)
#   6. TOGETHER_API_KEY
#   7. OLLAMA_ENDPOINT (local)
#   8. Mock provider (offline, no key needed)
#
# Example: Use Anthropic with Groq fallback
#   ANTHROPIC_API_KEY=sk-ant-v7-...
#   GROQ_API_KEY=gsk_...
#   (leave others blank)
